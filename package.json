{
  "name": "lottie-motion",
  "version": "0.1.0",
  "type": "module",
  "description": "Deterministic Node library compiling structure diagrams to Lottie vector animations",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.19"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/toby-bridges/lottie-motion.git"
  },
  "bugs": {
    "url": "https://github.com/toby-bridges/lottie-motion/issues"
  },
  "homepage": "https://github.com/toby-bridges/lottie-motion#readme",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc && npm run copy:assets",
    "copy:assets": "node -e \"const f=require('fs');f.mkdirSync('dist/gates/schema',{recursive:true});f.copyFileSync('src/gates/schema/lottie.schema.json','dist/gates/schema/lottie.schema.json');f.mkdirSync('dist/compiler/fonts',{recursive:true});for(const n of f.readdirSync('src/compiler/fonts'))f.copyFileSync('src/compiler/fonts/'+n,'dist/compiler/fonts/'+n)\"",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build && npm test"
  },
  "dependencies": {
    "@lottiefiles/last": "1.16.0",
    "@lottiefiles/last-builder": "1.15.0",
    "@lottiefiles/relottie": "1.15.0",
    "@lottiefiles/relottie-parse": "1.15.0",
    "@lottiefiles/relottie-stringify": "1.15.0",
    "ajv": "^8.12.0",
    "jsdom": "^29.1.1",
    "opentype.js": "^2.0.0"
  },
  "optionalDependencies": {
    "canvas": "^3.0.0",
    "lottie-web": "5.13.0"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.3",
    "@types/node": "^20.4.2",
    "tsx": "^4.22.4",
    "typescript": "^5.1.6",
    "vitest": "^4.1.10"
  },
  "keywords": [
    "lottie",
    "animation",
    "structure diagram",
    "flowchart",
    "deterministic"
  ],
  "author": "",
  "license": "MIT"
}
